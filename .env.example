OPENAI_API_KEY="<Your OpenAI API key>"
HUGGINGFACEHUB_API_TOKEN="<Your Huggingfacehub API Token>"

CONVERSATION_ENGINE="openai"

# Chat models shown in the model picker (comma-separated) and the default selection.
